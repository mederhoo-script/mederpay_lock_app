# ─────────────────────────────────────────────────────────────
#  MederBuy Web Platform — Environment Variables
#  Copy this file to .env.local and fill in your real values.
#
#    cp .env.example .env.local
#
#  NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════════════════════════
# SUPABASE
# Get these from: https://supabase.com/dashboard/project/<ref>/settings/api
# ═══════════════════════════════════════════════════════════════

# Your Supabase project URL  (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://abcdefghijklmnop.supabase.co

# Supabase anonymous (public) key  (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFiY2RlZmdoaWprbG1ub3AiLCJyb2xlIjoiYW5vbiIsImlhdCI6MTcwMDAwMDAwMCwiZXhwIjoyMDAwMDAwMDAwfQ.REPLACE_WITH_YOUR_ANON_KEY

# Supabase service-role key  ⚠️  SERVER ONLY — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFiY2RlZmdoaWprbG1ub3AiLCJyb2xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNzAwMDAwMDAwLCJleHAiOjIwMDAwMDAwMDB9.REPLACE_WITH_YOUR_SERVICE_ROLE_KEY


# ═══════════════════════════════════════════════════════════════
# MONNIFY PAYMENT GATEWAY
# Get these from: https://app.monnify.com  →  Settings → API Keys
# ═══════════════════════════════════════════════════════════════

# Monnify API key (identifies your merchant account)
MONNIFY_API_KEY=MK_TEST_SAF7HR5B3T

# Monnify secret key (used for webhook signature verification + authentication)
MONNIFY_SECRET_KEY=4SY6TNH57YKTQ4R3F8KNBHZEXPRDTUNK

# Monnify contract code (links virtual accounts to your merchant contract)
MONNIFY_CONTRACT_CODE=4934121686

# Monnify base URL
#   Sandbox (testing) : https://sandbox.monnify.com
#   Production (live)  : https://api.monnify.com
MONNIFY_BASE_URL=https://sandbox.monnify.com


# ═══════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════

# Full public URL of this deployment (no trailing slash)
#   Local dev : http://localhost:3000
#   Production : https://mederbuy.vercel.app
NEXT_PUBLIC_APP_URL=https://mederbuy.vercel.app

# Email address shown in the superadmin settings page
SUPERADMIN_EMAIL=admin@mederbuy.com


# ═══════════════════════════════════════════════════════════════
# CRON JOB AUTHENTICATION
# Used by Vercel Cron → /api/fees/calculate  and  /api/phones/lock-overdue
# Set the same secret in vercel.json and here.
# Generate a strong random value: openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════

CRON_SECRET=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2


# ═══════════════════════════════════════════════════════════════
# ANDROID DEVICE API SECRET
# Shared secret between the Android app and this server.
# The Android build must be compiled with the same value
# (see gradle.properties.example at the repo root).
# Generate a strong random value: openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════

ANDROID_DEVICE_API_SECRET=f9e8d7c6b5a4f9e8d7c6b5a4f9e8d7c6b5a4f9e8d7c6b5a4f9e8d7c6b5a4f9e8
