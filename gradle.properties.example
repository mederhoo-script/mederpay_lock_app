# ─────────────────────────────────────────────────────────────
#  MederBuy Android Build — Gradle Properties
#  Copy this file to gradle.properties and fill in your value.
#
#    cp gradle.properties.example gradle.properties
#
#  gradle.properties is already listed in .gitignore — NEVER
#  commit the real file with your secret.
# ─────────────────────────────────────────────────────────────

# Shared secret injected into BuildConfig.DEVICE_API_SECRET at compile time.
# The web server reads this via the x-device-secret header.
# Must match ANDROID_DEVICE_API_SECRET in web/.env.local exactly.
# Generate a strong random value: openssl rand -hex 32
ANDROID_DEVICE_API_SECRET=f9e8d7c6b5a4f9e8d7c6b5a4f9e8d7c6b5a4f9e8d7c6b5a4f9e8d7c6b5a4f9e8
